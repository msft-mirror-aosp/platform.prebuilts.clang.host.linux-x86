    {"ppc", ppcNames, "__builtin_"},
    {"r600", r600Names, "__builtin_r600_"},
    {"riscv", riscvNames, "__builtin_riscv_"},
    {"s390", s390Names, "__builtin_"},
    {"ve", veNames, "__builtin_ve_vl_"},
    {"x86", x86Names, "__builtin_ia32_"},
    {"xcore", xcoreNames, "__builtin_"},
