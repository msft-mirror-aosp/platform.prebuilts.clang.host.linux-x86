    return AttributeList::get(C, {
      {8, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(8))},
      {9, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(9))},
      {AttributeList::FunctionIndex, getIntrinsicFnAttributeSet(C, FnAttrID)}
