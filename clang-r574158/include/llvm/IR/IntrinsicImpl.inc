AttributeList Intrinsic::getAttributes(LLVMContext &C, ID id,
                                       FunctionType *FT) {
  if (id == 0)
    return AttributeList();

  uint16_t PackedID = IntrinsicsToAttributesMap[id - 1];
  uint8_t FnAttrID = PackedID >> 8;
  switch(PackedID & 0xFF) {
    default: llvm_unreachable("Invalid attribute number");
  case 5:
    return AttributeList();
  case 17:
    return AttributeList::get(C, {
      {1, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(1))},
      {2, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(2))},
      {4, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(4))}
    });
  case 15:
    return AttributeList::get(C, {
      {1, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(1))},
      {2, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(2))},
      {4, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(4))},
      {5, getIntrinsicArgAttributeSet(C, 0, FT->getContainedType(5))}
    });
  case 1:
    return AttributeList::get(C, {
      {AttributeList::FunctionIndex, getIntrinsicFnAttributeSet(C, FnAttrID)}
    });
  case 149:
    return AttributeList::get(C, {
      {9, getIntrinsicArgAttributeSet(C, 5, FT->getContainedType(9))},
      {AttributeList::FunctionIndex, getIntrinsicFnAttributeSet(C, FnAttrID)}
    });
  case 148:
    return AttributeList::get(C, {
      {8, getIntrinsicArgAttributeSet(C, 5, FT->getContainedType(8))},
      {AttributeList::FunctionIndex, getIntrinsicFnAttributeSet(C, FnAttrID)}
    });
